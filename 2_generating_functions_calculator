<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Generating Functions</title>
<style>
  /* Basic page styling */
  body {
    font-family: "Poppins", sans-serif;
    background-color: #1a1a1d;
    color: #f0f0f0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
  }
  h1 { color: #c77dff; margin-bottom: 1rem; }

  /* Container styling */
  .container {
    background-color: #2c2c34;
    border-radius: 20px;
    padding: 2rem;
    width: 90%;
    max-width: 700px;
    box-shadow: 0 0 10px #6a00f4;
  }

  /* Form inputs styling */
  select, textarea, input, button {
    width: 100%;
    padding: 0.8rem;
    border: none;
    border-radius: 10px;
    margin-bottom: 1rem;
    font-size: 1rem;
    background-color: #3d3d4a;
    color: #f0f0f0;
    resize: none;
  }

  button {
    background-color: #9d4edd;
    cursor: pointer;
    font-weight: bold;
  }

  button:hover { background-color: #c77dff; }

  /* Output styling */
  .output {
    background-color: #1f1f26;
    border-radius: 10px;
    padding: 1rem;
    margin-top: 1rem;
    font-family: monospace;
    white-space: pre-wrap;
  }

  /* Hint box styling */
  .hint {
    background-color: #262630;
    border-left: 4px solid #9d4edd;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
</style>
</head>
<body>
  <h1>🎲 Generating Functions</h1>
  <div class="container">
    <!-- Hint section -->
    <div class="hint" id="hint">Select a generator type for usage hint.</div>

    <!-- Generator type selection -->
    <label for="type">Generator type:</label>
    <select id="type" onchange="updateHint()">
      <option value="simple">Simple</option>
      <option value="exponential">Exponential</option>
    </select>

    <!-- Number of enumerators -->
    <label for="count">Number of enumerators:</label>
    <input type="number" id="count" min="1" value="3" onchange="renderEnumerators()">

    <!-- Container where enumerator inputs will appear -->
    <div id="enumerators"></div>

    <!-- Target term -->
    <label for="target">Target term (e.g., 10):</label>
    <input type="number" id="target" min="0" value="10">

    <!-- Button to compute -->
    <button onclick="generate()">🔍 Calculate</button>

    <!-- Output -->
    <div id="output" class="output"></div>
  </div>

<script>
// Updates the hint depending on the generator type
function updateHint() {
  const hint = document.getElementById("hint");
  const type = document.getElementById("type").value;
  if (type === "simple") {
    hint.textContent = "Simple generator → for selection problems (e.g., combinations, binomial expansions, distributions).";
  } else {
    hint.textContent = "Exponential generator → for arrangements or different objects without order.";
  }
}

// Renders input boxes for enumerators based on count
function renderEnumerators() {
  const container = document.getElementById("enumerators");
  const count = parseInt(document.getElementById("count").value);
  container.innerHTML = ""; // Clear previous
  for (let i = 1; i <= count; i++) {
    container.innerHTML += `
      <label for="enum${i}">Enumerator ${i} (accepts e.g., "0-4" or "0,2,4"):</label>
      <textarea id="enum${i}" rows="2" placeholder="0-3,5,7-9"></textarea>
    `;
  }
}

// Parses user input into an array of numbers
function parseValues(input) {
  const parts = input.split(/[\s,]+/).map(p => p.trim()).filter(p => p !== "");
  const values = new Set();

  for (const part of parts) {
    if (part.includes("-")) { // Range
      const [start, end] = part.split("-").map(Number);
      if (!isNaN(start) && !isNaN(end)) {
        for (let i = start; i <= end; i++) values.add(i);
      }
    } else { // Single number
      const num = parseInt(part);
      if (!isNaN(num)) values.add(num);
    }
  }

  return Array.from(values).sort((a, b) => a - b);
}

// Multiplies two polynomials represented as objects
function multiplyPolynomials(p1, p2) {
  const result = {};
  for (let e1 in p1) {
    for (let e2 in p2) {
      const exp = parseInt(e1) + parseInt(e2);
      result[exp] = (result[exp] || 0) + p1[e1] * p2[e2];
    }
  }
  return result;
}

// Main function to generate and calculate coefficient
function generate() {
  const count = parseInt(document.getElementById("count").value);
  const target = parseInt(document.getElementById("target").value);
  const generators = [];
  const polys = [];

  // Read enumerators and convert them to polynomials
  for (let i = 1; i <= count; i++) {
    const raw = document.getElementById(`enum${i}`).value;
    const values = parseValues(raw);
    const poly = {};
    values.forEach(exp => poly[exp] = 1); // Coefficient = 1
    polys.push(poly);
    const terms = values.map(v => `x^${v}`).join(" + ");
    generators.push(`(${terms})`);
  }

  // Multiply all polynomials
  let total = polys[0];
  for (let i = 1; i < polys.length; i++) total = multiplyPolynomials(total, polys[i]);

  // Create expanded polynomial string
  const expanded = Object.entries(total)
    .sort((a,b)=>a[0]-b[0])
    .map(([exp,coef])=> `${coef===1?"":coef}x^${exp}`)
    .join(" + ");

  const coefficient = total[target] || 0;

  // Show results
  document.getElementById("output").innerHTML =
    `Generating function:\n${generators.join(" * ")}\n\nExpansion:\n${expanded}\n\n➡️ Coefficient of x^${target} = ${coefficient}`;
}

// Initialize page
renderEnumerators();
updateHint();
</script>
</body>
</html>
