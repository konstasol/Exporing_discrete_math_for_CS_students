<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Γεννήτριες Συναρτήσεις</title>
<style>
  body {
    font-family: "Poppins", sans-serif;
    background-color: #1a1a1d;
    color: #f0f0f0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
  }
  h1 { color: #c77dff; margin-bottom: 1rem; }
  .container {
    background-color: #2c2c34;
    border-radius: 20px;
    padding: 2rem;
    width: 90%;
    max-width: 700px;
    box-shadow: 0 0 10px #6a00f4;
  }
  select, textarea, input, button {
    width: 100%;
    padding: 0.8rem;
    border: none;
    border-radius: 10px;
    margin-bottom: 1rem;
    font-size: 1rem;
    background-color: #3d3d4a;
    color: #f0f0f0;
    resize: none;
  }
  button {
    background-color: #9d4edd;
    cursor: pointer;
    font-weight: bold;
  }
  button:hover { background-color: #c77dff; }
  .output {
    background-color: #1f1f26;
    border-radius: 10px;
    padding: 1rem;
    margin-top: 1rem;
    font-family: monospace;
    white-space: pre-wrap;
  }
  .hint {
    background-color: #262630;
    border-left: 4px solid #9d4edd;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
</style>
</head>
<body>
  <h1>🎲 Γεννήτριες Συναρτήσεις</h1>
  <div class="container">
    <div class="hint" id="hint">Επίλεξε τύπο γεννήτριας για υπόδειξη χρήσης.</div>

    <label for="type">Τύπος γεννήτριας:</label>
    <select id="type" onchange="updateHint()">
      <option value="simple">Απλή</option>
      <option value="exponential">Εκθετική</option>
    </select>

    <label for="count">Πλήθος απαριθμητών:</label>
    <input type="number" id="count" min="1" value="3" onchange="renderEnumerators()">

    <div id="enumerators"></div>

    <label for="target">Όρος που ψάχνεις (π.χ. 10):</label>
    <input type="number" id="target" min="0" value="10">

    <button onclick="generate()">🔍 Υπολογισμός</button>
    <div id="output" class="output"></div>
  </div>

<script>
function updateHint() {
  const hint = document.getElementById("hint");
  const type = document.getElementById("type").value;
  if (type === "simple") {
    hint.textContent = "Απλή γεννήτρια → για προβλήματα επιλογής (π.χ. συνδυασμοί, διωνυμικά, κατανομές).";
  } else {
    hint.textContent = "Εκθετική γεννήτρια → για προβλήματα διατάξεων ή διαφορετικών αντικειμένων χωρίς σειρά.";
  }
}

function renderEnumerators() {
  const container = document.getElementById("enumerators");
  const count = parseInt(document.getElementById("count").value);
  container.innerHTML = "";
  for (let i = 1; i <= count; i++) {
    container.innerHTML += `
      <label for="enum${i}">Απαριθμητής ${i} (δέχεται π.χ. "0-4" ή "0,2,4"):</label>
      <textarea id="enum${i}" rows="2" placeholder="0-3,5,7-9"></textarea>
    `;
  }
}

function parseValues(input) {
  const parts = input.split(/[\s,]+/).map(p => p.trim()).filter(p => p !== "");
  const values = new Set();

  for (const part of parts) {
    if (part.includes("-")) {
      const [start, end] = part.split("-").map(Number);
      if (!isNaN(start) && !isNaN(end)) {
        for (let i = start; i <= end; i++) values.add(i);
      }
    } else {
      const num = parseInt(part);
      if (!isNaN(num)) values.add(num);
    }
  }

  return Array.from(values).sort((a, b) => a - b);
}

function multiplyPolynomials(p1, p2) {
  const result = {};
  for (let e1 in p1) {
    for (let e2 in p2) {
      const exp = parseInt(e1) + parseInt(e2);
      result[exp] = (result[exp] || 0) + p1[e1] * p2[e2];
    }
  }
  return result;
}

function generate() {
  const count = parseInt(document.getElementById("count").value);
  const target = parseInt(document.getElementById("target").value);
  const generators = [];
  const polys = [];
  const type = document.getElementById("type").value;

  for (let i = 1; i <= count; i++) {
    const raw = document.getElementById(`enum${i}`).value;
    const values = parseValues(raw);
    const poly = {};
    values.forEach(exp => poly[exp] = 1);
    polys.push(poly);
    const terms = values.map(v => type === "exponential" ? `x^${v}/${v}!` : `x^${v}`).join(" + ");
    generators.push(`(${terms})`);
  }

  let total = polys[0];
  for (let i = 1; i < polys.length; i++) total = multiplyPolynomials(total, polys[i]);

  const expanded = Object.entries(total)
    .sort((a,b)=>a[0]-b[0])
    .map(([exp,coef]) => {
      return type === "exponential" ? `${coef} x^${exp}/${exp}!` : `${coef===1?"":coef}x^${exp}`;
    })
    .join(" + ");

  const coefficient = total[target] || 0;

  const coefficientOutput = type === "exponential"
    ? `x^${target}/${target}! = ${coefficient}`
    : `x^${target} = ${coefficient}`;

  document.getElementById("output").innerHTML =
    `Η γεννήτρια είναι:\n${generators.join(" * ")}\n\nΑνάπτυγμα:\n${expanded}\n\n➡️ Συντελεστής του όρου ${coefficientOutput}`;
}

renderEnumerators();
updateHint();
</script>
</body>
</html>
